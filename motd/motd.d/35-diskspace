#!/data/data/com.termux/files/usr/bin/env bash
# KSUI diskspace — compact, one line per mount

b=$'\033[1m'; c=$'\e[1;36m'; w=$'\e[0;39m'; g=$'\e[1;32m'; y=$'\e[1;33m'; r=$'\e[1;31m'; nc=$'\033[0m'

printf "\n${b}Disk Usage:${nc}\n"

df -H 2>/dev/null \
  | awk 'NR>1 && $1 !~ /tmpfs|devtmpfs|overlay|apex/ && $6 ~ /^\/$|^\/data$|^\/storage|^\/home/ {print}' \
  | while read -r _fs total used _avail pct mount; do
      usage="${pct%\%}"
      [[ $usage =~ ^[0-9]+$ ]] || continue
      if   (( usage >= 95 )); then color=$r
      elif (( usage >= 75 )); then color=$y
      else                          color=$g
      fi
      printf "  ${c}%-30s${nc} ${color}%4s${nc} used out of ${w}%4s${nc}\n" \
        "$mount" "$used" "$total"
    done
