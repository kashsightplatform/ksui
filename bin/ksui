#!/data/data/com.termux/files/usr/bin/env bash
# KSUI — Kashsight UI shell (JARVIS-inspired)
# https://github.com/kashsightplatform/ksui

set -u

# Resolve repo root (supports symlinked install)
_self="${BASH_SOURCE[0]}"
while [[ -L $_self ]]; do _self="$(readlink "$_self")"; done
KSUI_HOME="$(cd "$(dirname "$_self")/.." && pwd)"
export KSUI_HOME

# shellcheck disable=SC1091
source "$KSUI_HOME/lib/ui.sh"
source "$KSUI_HOME/lib/voice.sh"
source "$KSUI_HOME/lib/sound.sh"
source "$KSUI_HOME/lib/auth.sh"
source "$KSUI_HOME/lib/commands.sh"
[[ -f "$KSUI_HOME/lib/banner.sh" ]] && source "$KSUI_HOME/lib/banner.sh"

export KSUI_VOICE="${KSUI_VOICE:-1}"
export KSUI_SOUNDS="${KSUI_SOUNDS:-1}"

ksui::boot_sequence() {
  clear
  ui::banner           # full motd: logo + sysinfo + datetime + disk
  sound::power_on
  printf "\n${C_DIM}  initializing subsystems...${C_RESET}\n"
  local steps=(
    "loading UI kernel"
    "mounting voice module"
    "calibrating neural net"
    "handshake with tgpt"
    "authentication ready"
  )
  # Fast path: skip per-step animation when KSUI_FAST_BOOT=1 (default on)
  if [[ ${KSUI_FAST_BOOT:-1} -eq 1 ]]; then
    for s in "${steps[@]}"; do ui::say_status OK "$s"; done
  else
    for s in "${steps[@]}"; do
      sleep 0.18
      ui::say_status OK "$s"
      sound::beep
    done
    sleep 0.3
  fi
  echo
  # Drain any keystrokes the user typed during boot — otherwise they leak
  # into the upcoming auth prompt and trigger phantom failed logins.
  if [[ -t 0 ]]; then
    stty sane 2>/dev/null
    while IFS= read -r -t 0 -n 1000 _drain 2>/dev/null; do :; done
  fi
}

ksui::post_login() {
  clear
  ui::banner
  voice::greet
  ui::maker_intro
  printf "\n  ${C_DIM}Type ${C_RESET}${C_GREEN}help${C_RESET}${C_DIM} for commands. ${C_RESET}${C_GREEN}exit${C_RESET}${C_DIM} to leave.${C_RESET}\n\n"
}

ksui::repl() {
  local line cmd args
  while :; do
    ui::prompt_char
    IFS= read -r line || { echo; break; }
    [[ -z ${line// } ]] && continue
    cmd=${line%% *}
    if [[ $line == *" "* ]]; then args=${line#* }; else args=""; fi

    case "$cmd" in
      help|h|?)     cmd::help ;;
      about|intro)  cmd::about ;;
      ask)          cmd::ask $args ;;
      joke)         cmd::joke ;;
      meme)         cmd::meme ;;
      fact)         cmd::fact ;;
      news)         cmd::news ;;
      crypto)       cmd::crypto $args ;;
      ip)           cmd::ip ;;
      define)       cmd::define $args ;;
      weather)      cmd::weather $args ;;
      sysinfo|sys)  cmd::sysinfo ;;
      qr)           cmd::qr $args ;;
      note)         cmd::note $args ;;
      notes)        cmd::notes ;;
      todo)         cmd::todo $args ;;
      timer)        cmd::timer $args ;;
      doctor)       cmd::doctor ;;
      motd)         ui::banner ;;
      banner)       cmd::banner $args ;;
      time|date)    date ;;
      ls)           ui::ls $args ;;
      ll)           ui::ll $args ;;
      cd)           cd "${args:-$HOME}" || ui::say_status ERR "cd failed" ;;
      clear|cls)    clear; ui::banner ;;
      voice)        cmd::voice_toggle $args ;;
      theme)        cmd::theme $args ;;
      update)       cmd::update ;;
      whoami)       cmd::whoami ;;
      reset-auth)   auth::reset; exit 0 ;;
      exit|quit|bye)
        voice::bye
        sound::power_off
        ui::say_status INFO "Shutting down KSUI…"
        sleep 0.6
        break
        ;;
      *)
        eval "$line"
        ;;
    esac
  done
}

ksui::usage() {
  cat <<EOF
ksui — Kashsight UI shell

USAGE:
  ksui                       Launch interactive shell (login + REPL)
  ksui ask <question...>     One-shot: ask KAI, print answer, exit
  ksui joke | fact           One-shot: joke / fact (tgpt)
  ksui news                  Top headlines (Hacker News)
  ksui crypto [coin]         Crypto price (CoinGecko)
  ksui ip                    Public IP + geo
  ksui define <word>         Dictionary lookup
  ksui weather [city]        Current weather (wttr.in)
  ksui sysinfo               System info
  ksui qr <text>             Render a terminal QR code
  ksui note <text>           Append a timestamped note
  ksui notes                 Show all notes
  ksui todo [text|done N]    Todo list
  ksui timer <minutes>       Pomodoro timer
  ksui doctor                Audit optional deps + KSUI health
  ksui motd                  Print the motd banner
  ksui banner <text>         Build custom banner (letters/digits only)
  ksui update                Pull latest + re-run installer
  ksui theme [name]          List / switch prompt themes

FLAGS:
  --no-voice      Start with voice muted
  --no-sounds     Disable sound effects
  --reset-auth    Clear saved credentials
  --version, -v   Print version
  --help, -h      Print this help
EOF
}

main() {
  # Parse flags that can appear before a subcommand
  local passthrough=()
  while (( $# )); do
    case "${1:-}" in
      --version|-v) echo "ksui 0.3.0"; exit 0 ;;
      --help|-h)    ksui::usage; exit 0 ;;
      --reset-auth) auth::reset; exit 0 ;;
      --no-voice)   export KSUI_VOICE=0; shift ;;
      --no-sounds)  export KSUI_SOUNDS=0; shift ;;
      *)            passthrough+=("$1"); shift ;;
    esac
  done
  set -- "${passthrough[@]:-}"

  # One-shot mode: `ksui ask ...`, `ksui joke`, etc.
  case "${1:-}" in
    ask)       shift; cmd::ask "$@"; exit $? ;;
    joke)      cmd::joke; exit $? ;;
    fact)      cmd::fact; exit $? ;;
    meme)      cmd::meme; exit $? ;;
    news)      cmd::news; exit $? ;;
    crypto)    shift; cmd::crypto "$@"; exit $? ;;
    ip)        cmd::ip; exit $? ;;
    define)    shift; cmd::define "$@"; exit $? ;;
    weather)   shift; cmd::weather "$@"; exit $? ;;
    sysinfo)   cmd::sysinfo; exit $? ;;
    qr)        shift; cmd::qr "$@"; exit $? ;;
    note)      shift; cmd::note "$@"; exit $? ;;
    notes)     cmd::notes; exit $? ;;
    todo)      shift; cmd::todo "$@"; exit $? ;;
    timer)     shift; cmd::timer "$@"; exit $? ;;
    doctor)    cmd::doctor; exit $? ;;
    motd)      ui::banner; exit 0 ;;
    banner)    shift; cmd::banner "$@"; exit $? ;;
    update)    cmd::update; exit $? ;;
    theme)     shift; cmd::theme "$@"; exit $? ;;
    "")        : ;;
    *)         ksui::usage; exit 1 ;;
  esac

  # Interactive mode
  ksui::boot_sequence
  auth::login || exit 1
  ksui::post_login
  ksui::repl
}

main "$@"
